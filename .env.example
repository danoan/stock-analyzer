# Copy this file to .env and fill in real values before running docker-compose.
# .env is gitignored and must never be committed.
#
# NOTE: Passwords must not contain single quotes (') due to how they are
# interpolated into the Postgres init script.

# Postgres superuser (used only for initial setup and admin tasks)
POSTGRES_DB=stock_analyzer
POSTGRES_USER=stock_user
POSTGRES_PASSWORD=changeme

# data-ingestor login user (write access: CREATE TABLE + INSERT)
INGESTOR_DB_USER=ingestor_user
INGESTOR_DB_PASSWORD=changeme

# Metabase login user (read-only SELECT access)
METABASE_DB_USER=metabase_user
METABASE_DB_PASSWORD=changeme

# OpenAI — used by fundascope
OPENAI_API_KEY=
